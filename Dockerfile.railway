# 星航图 - Whisper 语音识别代理
# 部署到 Railway

FROM python:3.11-slim

WORKDIR /app

# 安装依赖
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 复制代码
COPY whisper-proxy-railway.py .

# 暴露端口
EXPOSE 8080

# 启动命令（Railway 会用 $PORT 环境变量）
CMD ["sh", "-c", "gunicorn -b 0.0.0.0:$PORT --workers 2 whisper-proxy-railway:app"]
